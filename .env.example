# ==============================================================================
# Environment Variables — Drupal + MariaDB (Vector) + Redis Stack
# ==============================================================================
# Copy this file to .env and fill in the secrets.
# DO NOT commit .env to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Drupal Runtime
# ------------------------------------------------------------------------------
PHP_VERSION=8.3
DEBIAN_VERSION=bookworm
DRUPAL_HTTP_PORT=8080
DRUPAL_HASH_SALT=change-me-to-a-64-character-random-string-abcdefghijklmnopqrstuvwxyz0123456789abcd
DRUPAL_MAINTENANCE_MODE=false

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
DB_NAME=drupal
DB_USER=drupal
DB_PASSWORD=ChangeMeToASecurePassword!
DB_ROOT_PASSWORD=ChangeMeToAnEvenStrongerRootPassword!
DB_EXPOSE_PORT=127.0.0.1:3306

# ------------------------------------------------------------------------------
# MariaDB Server Tuning
# ------------------------------------------------------------------------------
MARIADB_VERSION=11
MARIADB_PERFORMANCE_SCHEMA=OFF
MARIADB_CPU_LIMIT=2
MARIADB_MEM_LIMIT=1G
MARIADB_CPU_RESERVE=0.5
MARIADB_MEM_RESERVE=256M

# ------------------------------------------------------------------------------
# Redis Stack
# ------------------------------------------------------------------------------
REDIS_VERSION=latest
REDIS_PASSWORD=ChangeMeRedisSecurePass!
REDIS_MAXMEMORY=512mb
REDIS_EXPOSE_PORT=127.0.0.1:6379
REDIS_CPU_LIMIT=1
REDIS_MEM_LIMIT=512M
REDIS_CPU_RESERVE=0.25
REDIS_MEM_RESERVE=128M

# ------------------------------------------------------------------------------
# phpMyAdmin
# ------------------------------------------------------------------------------
PHPMYADMIN_VERSION=latest
PHPMYADMIN_PORT=127.0.0.1:8081
PMA_UPLOAD_LIMIT=128M
PMA_MEMORY_LIMIT=512M
PMA_MAX_EXECUTION_TIME=600
